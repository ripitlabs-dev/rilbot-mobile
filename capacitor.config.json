{
  "appId": "com.ripitlabs.rilbot",
  "appName": "RILBOT",
  "webDir": "dist",
  "server": {
    "url": "https://rilbot.ripitlabs.com",
    "cleartext": false,
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0a0a0f",
      "showSpinner": false,
      "androidSplashResourceName": "splash",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#0a0a0f"
    }
  }
}
